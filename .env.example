# Copy to `.env` and adjust as needed.

# Ollama (must be running locally — see https://ollama.com)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Embeddings (downloaded automatically on first run)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
TOP_K=6

# Speech-to-Text (only used if requirements-voice.txt is installed)
# Try "openai/whisper-tiny" for multilingual, "openai/whisper-base" for higher accuracy.
WHISPER_MODEL=openai/whisper-tiny.en

# JWT signing key — generate a long random string in production
JWT_SECRET=change-me-in-production

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
